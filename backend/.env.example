DATABASE_URL=sqlite:///./agent_marketplace.db
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# MCP filesystem workspace (defaults to repo root when unset)
MCP_WORKSPACE_ROOT=
MCP_ENABLED=true

# CSPR.cloud Casper MCP (testnet hosted server)
CSPR_CLOUD_API_KEY=
CSPR_MCP_URL=https://mcp.testnet.cspr.cloud/mcp
CSPR_MCP_ENABLED=true

# SQLite paths are resolved relative to the repo root.
# Remove DATABASE_URL entirely to use the default: agent_marketplace.db at repo root.
